# .env.local.example — copiar como .env.local y completar
# NUNCA subir .env.local a Git

# URL base del backend PHP (sin slash final)
# En local: donde corre XAMPP
# En producción: URL pública del sitio PHP
PHP_API_URL=http://localhost/radio-escolar

# URL pública del stream (se pone también en el panel admin)
NEXT_PUBLIC_STREAM_URL=https://radios.solumedia.com:6740/stream

# URL base del API accesible desde el browser (vacío = mismo dominio)
NEXT_PUBLIC_API_BASE=
